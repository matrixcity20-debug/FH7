# BUL-10: .dockerignore — prevent secrets and dev files leaking into Docker image

# Version control
.git
.gitignore

# Dev / editor
.env
.env.*
*.local
.vscode
.idea
*.swp
*.swo

# OS artefacts
.DS_Store
Thumbs.db

# Dependency caches (reinstalled inside image)
node_modules

# Test & coverage
coverage
*.test.ts
*.spec.ts

# Build artefacts already handled by multi-stage build
dist

# Uploads / user data (never bake into image)
uploads
_uploads
_sessions
_users.json

# Docs
*.md
LICENSE
