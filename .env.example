# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║                     FileSplit — Ortam Değişkenleri                          ║
# ║                                                                              ║
# ║  Bu dosya .env.example olarak saklanır; asla gerçek değerler içermemelidir. ║
# ║  Üretim ortamında bu değişkenleri Render.com → Environment bölümünde        ║
# ║  doğrudan ayarlayın. Asla bu dosyayı gerçek değerlerle doldurup             ║
# ║  git'e commit etmeyin.                                                       ║
# ╚══════════════════════════════════════════════════════════════════════════════╝


# ─────────────────────────────────────────────────────────────────────────────
# ▶  SUNUCU TEMEL AYARLARI
# ─────────────────────────────────────────────────────────────────────────────

# Node.js çalışma modu.
# Üretimde mutlaka "production" olmalı; aksi hâlde güvenlik başlıkları
# ve hata gizleme devreye girmez.
# Değerler: production | development
NODE_ENV=production

# Sunucunun dinleyeceği TCP port numarası.
# Render.com bu değeri otomatik olarak atar; elle ayarlamayın.
PORT=5000

# Oturum imzalama için kullanılan gizli anahtar.
# En az 64 karakterlik rastgele bir dize olmalıdır.
# Değiştirirseniz tüm aktif kullanıcı oturumları geçersiz hâle gelir.
# Üretim için oluşturma komutu: openssl rand -hex 64
SESSION_SECRET=BURAYA_EN_AZ_64_KARAKTERLIK_RASTGELE_DEGER_GIRIN


# ─────────────────────────────────────────────────────────────────────────────
# ▶  YETKİLENDİRME & ERİŞİM DENETİMİ
# ─────────────────────────────────────────────────────────────────────────────

# Yönetici yetkisi verilecek kullanıcı UUID'leri.
# Virgülle ayrılmış liste. Bu kullanıcılar /admin paneline erişebilir.
# Değeri bulmak için: kayıt olduktan sonra Firebase'den kendi user ID'nizi alın.
# Örnek: fbfd3f42-b3bf-48d9-8a8a-325726916160,aabb1234-ccdd-...
ADMIN_USER_IDS=

# Uygulamanın barındırıldığı alan adları (CORS & URL üretimi için).
# Birden fazla alan adı varsa virgülle ayırın.
# Boş bırakılırsa Host başlığından otomatik algılanır (güvenlik riski).
# Render.com'daki tam URL'nizi yazın.
# Örnek: https://filesplithosting.onrender.com
ALLOWED_ORIGINS=https://sizin-render-url-iniz.onrender.com


# ─────────────────────────────────────────────────────────────────────────────
# ▶  FIREBASE REALTIME DATABASE
# ─────────────────────────────────────────────────────────────────────────────
# Firebase, dosya meta verilerini ve şifreleme anahtarlarını saklar.
# Konsol: https://console.firebase.google.com
# Servis hesabı oluşturmak için:
#   Proje → Proje Ayarları → Servis Hesapları →
#   "Yeni özel anahtar oluştur" → JSON dosyasını indirin.

# Firebase projenizin kimliği (JSON dosyasındaki "project_id" alanı).
FIREBASE_PROJECT_ID=sizin-firebase-proje-id

# Servis hesabı e-posta adresi (JSON dosyasındaki "client_email" alanı).
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@sizin-proje.iam.gserviceaccount.com

# Servis hesabı özel anahtarı (JSON dosyasındaki "private_key" alanı).
# ÖNEMLİ: Başındaki ve sonundaki tırnak işaretlerini dahil edin.
# Render.com'da değeri ayarlarken \n karakterlerinin korunduğundan emin olun.
FIREBASE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nBURAYA_ANAHTARI_YAPISTIRIN\n-----END RSA PRIVATE KEY-----\n"

# Realtime Database URL'si.
# Firebase Console → Realtime Database → Veri sekmesindeki URL.
# Örnek: https://sizin-proje-default-rtdb.europe-west1.firebasedatabase.app
FIREBASE_DATABASE_URL=https://sizin-proje-default-rtdb.bolge.firebasedatabase.app


# ─────────────────────────────────────────────────────────────────────────────
# ▶  CLOUDFLARE R2 — NESNE DEPOLAMA (SAĞLAYICI 1)
# ─────────────────────────────────────────────────────────────────────────────
# Cloudflare R2, dosya parçalarını (chunk) AES-256-GCM ile şifrelenmiş olarak
# saklar. Şifreleme anahtarı R2'ye hiçbir zaman yazılmaz; yalnızca Firebase'de
# tutulur. R2 tanımlanmazsa sistem yalnızca B2 ile çalışır.
# Konsol: https://dash.cloudflare.com → R2 Object Storage

# Cloudflare hesap kimliği.
# Cloudflare Dashboard → sağ alt köşedeki "Account ID" alanından kopyalayın.
R2_ACCOUNT_ID=0123456789abcdef0123456789abcdef

# R2 API Token erişim anahtarı.
# Cloudflare → R2 → API token oluştur → "Object Read & Write" izinleri.
R2_ACCESS_KEY_ID=BURAYA_R2_ACCESS_KEY_ID

# R2 API Token gizli anahtarı.
# Token oluşturulurken bir kez gösterilir; güvenli saklayın.
R2_SECRET_ACCESS_KEY=BURAYA_R2_SECRET_ACCESS_KEY

# Birden fazla R2 bucket kullanıyorsanız (round-robin yük dağıtımı için):
# Virgülle ayrılmış bucket adları listesi. Bu tanımlandığında R2_BUCKET_NAME
# görmezden gelinir.
# Örnek: dosyalar-eu,dosyalar-us,dosyalar-as
R2_BUCKET_NAMES=

# Tek R2 bucket kullanıyorsanız (R2_BUCKET_NAMES tanımlı değilse kullanılır):
R2_BUCKET_NAME=sizin-r2-bucket-adi


# ─────────────────────────────────────────────────────────────────────────────
# ▶  BACKBLAZE B2 — NESNE DEPOLAMA (SAĞLAYICI 2)
# ─────────────────────────────────────────────────────────────────────────────
# B2, Cloudflare R2 ile birlikte round-robin yük dağıtımı yapar.
# Her iki servis de aynı AES-256-GCM şifrelemesini kullanır.
# Yalnızca B2 tanımlanırsa R2 olmadan da tam işlevli çalışır.
# Konsol: https://secure.backblaze.com/b2_buckets.htm

# B2 Application Key ID (S3-uyumlu erişim anahtarı).
# Backblaze Console → App Keys → "Add a New Application Key" →
# "S3 Compatible API" seçeneğiyle oluşturun.
B2_KEY_ID=BURAYA_B2_APPLICATION_KEY_ID

# B2 Application Key (S3-uyumlu gizli anahtar).
# Key oluşturulurken bir kez gösterilir; güvenli saklayın.
B2_APP_KEY=BURAYA_B2_APPLICATION_KEY

# B2 S3-uyumlu endpoint URL'si.
# Bucket oluşturduktan sonra Backblaze Console → Bucket Details →
# "Endpoint" alanından kopyalayın.
# Format: https://s3.{region}.backblazeb2.com
# Örnek: https://s3.us-west-004.backblazeb2.com
B2_ENDPOINT=https://s3.BOLGE.backblazeb2.com

# Birden fazla B2 bucket kullanıyorsanız (round-robin için):
# Virgülle ayrılmış bucket adları. Bu tanımlandığında B2_BUCKET_NAME
# görmezden gelinir.
# Örnek: dosyalar-b2-1,dosyalar-b2-2
B2_BUCKET_NAMES=

# Tek B2 bucket kullanıyorsanız (B2_BUCKET_NAMES tanımlı değilse kullanılır):
B2_BUCKET_NAME=sizin-b2-bucket-adi


# ─────────────────────────────────────────────────────────────────────────────
# ▶  UYGULAMA LİMİTLERİ
# ─────────────────────────────────────────────────────────────────────────────
# Bu değerler tanımlı değilse aşağıdaki varsayılanlar uygulanır.
# Bireysel kullanıcı limitleri admin panelinden ayrıca ayarlanabilir.

# Kullanıcı başına varsayılan depolama kotası (MB cinsinden).
# Varsayılan: 5120 (5 GB)
MAX_USER_STORAGE_MB=5120

# İzin verilen maksimum dosya boyutu (MB cinsinden).
# Varsayılan: 500 (500 MB)
MAX_FILE_SIZE_MB=500

# Dosyaların bölüneceği parça boyutu (MB cinsinden).
# Küçük değer → daha fazla nesne (maliyet artar).
# Büyük değer → daha fazla bellek tüketimi.
# Varsayılan: 1 (1 MB)
CHUNK_SIZE_MB=1


# ─────────────────────────────────────────────────────────────────────────────
# ▶  GÜNLÜK (LOG) AYARLARI
# ─────────────────────────────────────────────────────────────────────────────

# Günlük ayrıntı seviyesi.
# Üretimde "info" önerilir. Hata ayıklarken "debug" kullanın.
# Değerler: trace | debug | info | warn | error | fatal
# Varsayılan: info
LOG_LEVEL=info
