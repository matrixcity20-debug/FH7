# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║                     FileSplit — Ortam Değişkenleri                          ║
# ║                                                                              ║
# ║  Bu dosya .env.example olarak saklanır; asla gerçek değerler içermemelidir. ║
# ║  Üretim ortamında bu değişkenleri Render.com → Environment bölümünde        ║
# ║  doğrudan ayarlayın. Asla bu dosyayı gerçek değerlerle doldurup             ║
# ║  git'e commit etmeyin.                                                       ║
# ╚══════════════════════════════════════════════════════════════════════════════╝


# ─────────────────────────────────────────────────────────────────────────────
# ▶  SUNUCU TEMEL AYARLARI
# ─────────────────────────────────────────────────────────────────────────────

# Node.js çalışma modu.
# Üretimde mutlaka "production" olmalı; aksi hâlde güvenlik başlıkları
# ve hata gizleme devreye girmez.
# Değerler: production | development
NODE_ENV=production

# Sunucunun dinleyeceği TCP port numarası.
# Render.com bu değeri otomatik olarak atar; elle ayarlamayın.
PORT=5000

# Oturum imzalama için kullanılan gizli anahtar.
# En az 64 karakterlik rastgele bir dize olmalıdır.
# Değiştirirseniz tüm aktif kullanıcı oturumları geçersiz hâle gelir.
# Üretim için oluşturma komutu: openssl rand -hex 64
SESSION_SECRET=BURAYA_EN_AZ_64_KARAKTERLIK_RASTGELE_DEGER_GIRIN


# ─────────────────────────────────────────────────────────────────────────────
# ▶  YETKİLENDİRME & ERİŞİM DENETİMİ
# ─────────────────────────────────────────────────────────────────────────────

# Yönetici yetkisi verilecek kullanıcı UUID'leri.
# Virgülle ayrılmış liste. Bu kullanıcılar /admin paneline erişebilir.
# Değeri bulmak için: kayıt olduktan sonra Firebase'den kendi user ID'nizi alın.
# Örnek: fbfd3f42-b3bf-48d9-8a8a-325726916160,aabb1234-ccdd-...
ADMIN_USER_IDS=

# Uygulamanın barındırıldığı alan adları (CORS & URL üretimi için).
# Birden fazla alan adı varsa virgülle ayırın.
# Boş bırakılırsa Host başlığından otomatik algılanır (güvenlik riski).
# Render.com'daki tam URL'nizi yazın.
# Örnek: https://filesplithosting.onrender.com
ALLOWED_ORIGINS=https://sizin-render-url-iniz.onrender.com


# ─────────────────────────────────────────────────────────────────────────────
# ▶  FIREBASE REALTIME DATABASE
# ─────────────────────────────────────────────────────────────────────────────
# Firebase, dosya meta verilerini ve şifreleme anahtarlarını saklar.
# Konsol: https://console.firebase.google.com
# Servis hesabı oluşturmak için:
#   Proje → Proje Ayarları → Servis Hesapları →
#   "Yeni özel anahtar oluştur" → JSON dosyasını indirin.

# Firebase projenizin kimliği (JSON dosyasındaki "project_id" alanı).
FIREBASE_PROJECT_ID=sizin-firebase-proje-id

# Servis hesabı e-posta adresi (JSON dosyasındaki "client_email" alanı).
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@sizin-proje.iam.gserviceaccount.com

# Servis hesabı özel anahtarı (JSON dosyasındaki "private_key" alanı).
# ÖNEMLİ: Başındaki ve sonundaki tırnak işaretlerini dahil edin.
# Render.com'da değeri ayarlarken \n karakterlerinin korunduğundan emin olun.
FIREBASE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nBURAYA_ANAHTARI_YAPISTIRIN\n-----END RSA PRIVATE KEY-----\n"

# Realtime Database URL'si.
# Firebase Console → Realtime Database → Veri sekmesindeki URL.
# Örnek: https://sizin-proje-default-rtdb.europe-west1.firebasedatabase.app
FIREBASE_DATABASE_URL=https://sizin-proje-default-rtdb.bolge.firebasedatabase.app


# ═════════════════════════════════════════════════════════════════════════════
# ▶  DEPOLAMA SAĞLAYICILARI — ÇOKLU HESAP FORMATI
# ═════════════════════════════════════════════════════════════════════════════
#
# FileSplit, R2 + B2 + e2'yi eş zamanlı destekler. Tanımlı tüm hesap+bucket
# kombinasyonları global round-robin havuzuna otomatik eklenir.
#
# ┌─────────────────────────────────────────────────────────────────────────┐
# │  HESAP AYIRICI  : virgül  ,                                             │
# │  BUCKET AYIRICI : pipe    |   (aynı hesapta birden fazla bucket)        │
# └─────────────────────────────────────────────────────────────────────────┘
#
# Her env var virgülle ayrılmış değer dizisi içerir.
# Aynı konumdaki değerler bir hesabı oluşturur.
#
#   E2_ACCESS_KEY_ID     = key-A,key-B,key-C
#   E2_SECRET_ACCESS_KEY = sec-A,sec-B,sec-C
#   E2_ENDPOINT          = https://ep-A.com,https://ep-B.com,https://ep-C.com
#   E2_BUCKET_NAMES      = bucketA1|bucketA2,bucketB1,bucketC1|bucketC2|bucketC3
#
#   Hesap 1 → key-A + sec-A + ep-A  → bucket: bucketA1, bucketA2
#   Hesap 2 → key-B + sec-B + ep-B  → bucket: bucketB1
#   Hesap 3 → key-C + sec-C + ep-C  → bucket: bucketC1, bucketC2, bucketC3
#
# Tek hesap / tek bucket — virgül ve pipe gerekmez (geriye uyumlu):
#
#   E2_ACCESS_KEY_ID     = tek-key
#   E2_SECRET_ACCESS_KEY = tek-secret
#   E2_ENDPOINT          = https://hesap.s3.us-e-1.idrivecloud.io
#   E2_BUCKET_NAMES      = benim-bucket
#
# DOĞRULAMA: Bir provider'daki tüm kimlik bilgisi dizileri eşit uzunlukta
# olmalıdır. Eşitsizlik varsa o provider tamamen devre dışı bırakılır ve
# açık hata mesajı loglanır. Kısmi yapılandırma kabul edilmez.
#
# GÜVENLİK: Şifreleme anahtarları hiçbir zaman depolama servislerine
# yazılmaz; yalnızca Firebase'de saklanır. Kimlik bilgileri log satırlarına
# hiçbir koşulda dahil edilmez.


# ─────────────────────────────────────────────────────────────────────────────
# ▶  CLOUDFLARE R2 — NESNE DEPOLAMA (SAĞLAYICI 1)
# ─────────────────────────────────────────────────────────────────────────────
# Konsol: https://dash.cloudflare.com → R2 Object Storage
# Token: Cloudflare → R2 → "Manage R2 API Tokens" → Object Read & Write

# Cloudflare hesap kimliği/kimlikleri — Dashboard → sağ alt köşe → "Account ID"
# Tek hesap  : R2_ACCOUNT_ID=acct-id-1
# Çok hesap  : R2_ACCOUNT_ID=acct-id-1,acct-id-2,acct-id-3
R2_ACCOUNT_ID=acct-id-1,acct-id-2

# R2 API Token erişim anahtarları (R2_ACCOUNT_ID ile aynı sırada)
R2_ACCESS_KEY_ID=key-1,key-2

# R2 API Token gizli anahtarları (oluşturulurken bir kez gösterilir)
R2_SECRET_ACCESS_KEY=secret-1,secret-2

# Bucket konfigürasyonu
# Virgül = hesap sınırı   |   Pipe = aynı hesapta birden fazla bucket
# Örnek : "bkt-eu|bkt-eu2,bkt-us"  →  Hesap 1: [bkt-eu, bkt-eu2]  Hesap 2: [bkt-us]
R2_BUCKET_NAMES=bkt-r2-1|bkt-r2-2,bkt-r2-3


# ─────────────────────────────────────────────────────────────────────────────
# ▶  BACKBLAZE B2 — NESNE DEPOLAMA (SAĞLAYICI 2)
# ─────────────────────────────────────────────────────────────────────────────
# Konsol: https://secure.backblaze.com/b2_buckets.htm
# Token: App Keys → "Add a New Application Key" → S3 Compatible API seçin

# B2 Application Key ID'leri
# Tek hesap  : B2_KEY_ID=keyid-1
# Çok hesap  : B2_KEY_ID=keyid-1,keyid-2,keyid-3
B2_KEY_ID=b2keyid-1,b2keyid-2

# B2 Application Key'leri (oluşturulurken bir kez gösterilir)
B2_APP_KEY=b2appkey-1,b2appkey-2

# B2 S3-uyumlu endpoint URL'leri — Bucket Details → "Endpoint" alanından kopyalayın
# Format: https://s3.{bölge}.backblazeb2.com
B2_ENDPOINT=https://s3.us-west-004.backblazeb2.com,https://s3.eu-central-003.backblazeb2.com

# Bucket konfigürasyonu (virgül=hesap, pipe=hesap-içi-bucket)
B2_BUCKET_NAMES=bkt-b2-1|bkt-b2-2,bkt-b2-3


# ─────────────────────────────────────────────────────────────────────────────
# ▶  IDRIVE E2 — NESNE DEPOLAMA (SAĞLAYICI 3)
# ─────────────────────────────────────────────────────────────────────────────
# Konsol: https://app.idrive.com/e2/home
# Token: Access Keys → "Generate New Access Key"
# Endpoint formatı: https://{HESAP_ID}.s3.{BOLGE}.idrivecloud.io
# (Bucket oluşturduktan sonra bucket detay sayfasından kopyalayın)

# iDrive e2 Access Key ID'leri
# Tek hesap  : E2_ACCESS_KEY_ID=tek-key
# Çok hesap  : E2_ACCESS_KEY_ID=key-1,key-2,key-3
E2_ACCESS_KEY_ID=e2key-1,e2key-2,e2key-3

# iDrive e2 Secret Access Key'leri (oluşturulurken bir kez gösterilir)
E2_SECRET_ACCESS_KEY=e2secret-1,e2secret-2,e2secret-3

# iDrive e2 S3-uyumlu endpoint URL'leri
E2_ENDPOINT=https://acct1.s3.us-e-1.idrivecloud.io,https://acct2.s3.eu-c-1.idrivecloud.io,https://acct3.s3.us-or-1.idrivecloud.io

# Bucket konfigürasyonu (virgül=hesap, pipe=hesap-içi-bucket)
E2_BUCKET_NAMES=e2-bucket1|e2-bucket2,e2-bucket3,e2-bucket4|e2-bucket5|e2-bucket6


# ─────────────────────────────────────────────────────────────────────────────
# ▶  UYGULAMA LİMİTLERİ
# ─────────────────────────────────────────────────────────────────────────────
# Bu değerler tanımlı değilse aşağıdaki varsayılanlar uygulanır.
# Bireysel kullanıcı limitleri admin panelinden ayrıca ayarlanabilir.

# Kullanıcı başına varsayılan depolama kotası (MB cinsinden).
# Varsayılan: 5120 (5 GB)
MAX_USER_STORAGE_MB=5120

# İzin verilen maksimum dosya boyutu (MB cinsinden).
# Varsayılan: 500 (500 MB)
MAX_FILE_SIZE_MB=500

# Dosyaların bölüneceği parça boyutu (MB cinsinden).
# Küçük değer → daha fazla nesne (maliyet artar).
# Büyük değer → daha fazla bellek tüketimi.
# Varsayılan: 1 (1 MB)
CHUNK_SIZE_MB=1


# ─────────────────────────────────────────────────────────────────────────────
# ▶  GÜNLÜK (LOG) AYARLARI
# ─────────────────────────────────────────────────────────────────────────────

# Günlük ayrıntı seviyesi.
# Üretimde "info" önerilir. Hata ayıklarken "debug" kullanın.
# Değerler: trace | debug | info | warn | error | fatal
# Varsayılan: info
LOG_LEVEL=info
